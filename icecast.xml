<icecast>
    <location>Arborisis Radio</location>
    <admin>contact@arborisis.com</admin>
    
    <limits>
        <clients>1000</clients>
        <sources>5</sources>
        <queue-size>524288</queue-size>
        <client-timeout>30</client-timeout>
        <header-timeout>15</header-timeout>
        <source-timeout>10</source-timeout>
        <burst-on-connect>1</burst-on-connect>
        <burst-size>65535</burst-size>
    </limits>
    
    <authentication>
        <source-password>${ICECAST_SOURCE_PASSWORD:-source}</source-password>
        <relay-password>${ICECAST_RELAY_PASSWORD:-relay}</relay-password>
        <admin-user>admin</admin-user>
        <admin-password>${ICECAST_ADMIN_PASSWORD:-admin}</admin-password>
    </authentication>
    
    <hostname>0.0.0.0</hostname>
    
    <listen-socket>
        <port>8000</port>
        <!-- Utiliser ${PORT} pour Railway -->
    </listen-socket>
    
    <fileserve>1</fileserve>
    
    <paths>
        <basedir>/usr/share/icecast2</basedir>
        <logdir>/var/log/icecast2</logdir>
        <webroot>/usr/share/icecast2/web</webroot>
        <adminroot>/usr/share/icecast2/admin</adminroot>
        <alias source="/" dest="/status.xsl"/>
    </paths>
    
    <logging>
        <accesslog>icecast_access.log</accesslog>
        <errorlog>icecast_error.log</errorlog>
        <loglevel>3</loglevel>
        <logsize>10000</logsize>
    </logging>
    
    <security>
        <chroot>0</chroot>
        <changeowner>
            <user>root</user>
            <group>root</group>
        </changeowner>
    </security>
    
    <!-- Mount point pour la radio Arborisis -->
    <mount>
        <mount-name>/arborisis.mp3</mount-name>
        <charset>UTF8</charset>
        <public>1</public>
        <stream-name>Arborisis Radio</stream-name>
        <stream-description>Radio nature et sons de la forêt</stream-description>
        <stream-url>https://arborisis.com</stream-url>
        <genre>Nature, Ambient</genre>
        <bitrate>128</bitrate>
        <type>audio/mpeg</type>
        <subtype>mp3</subtype>
        <!-- Fallback en cas de déconnexion source -->
        <fallback-mount>/fallback.mp3</fallback-mount>
        <fallback-override>1</fallback-override>
        <fallback-when-full>1</fallback-when-full>
    </mount>
</icecast>
